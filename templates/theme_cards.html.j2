<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>{{ character.name }} — Theme Cards</title>
<style>
  /* A6 landscape ≈ 148×105mm — close to the index-card feel of CoM theme cards.
     Use A5 landscape for slightly more breathing room. */
  @page {
    size: A5 landscape;
    margin: 8mm;
  }

  :root {
    --ink: #14110f;
    --paper: #faf6ef;
    --accent: #7a2222;
    --muted: #6a655c;
    --rule: #2a2622;
    --tag-bg: #f1ead9;
  }

  * { box-sizing: border-box; }

  html, body {
    margin: 0;
    padding: 0;
    background: #ffffff;
    color: var(--ink);
    font-family: "Helvetica Neue", Helvetica, "Inter", "Avenir Next", Arial, sans-serif;
    font-size: 11pt;
    line-height: 1.4;
  }

  .card {
    page-break-after: always;
    break-after: page;
    border: 2px solid var(--rule);
    border-radius: 3px;
    padding: 6mm 8mm;
    height: calc(100vh - 16mm);
    display: flex;
    flex-direction: column;
    position: relative;
    background: var(--paper);
  }
  .card:last-child {
    page-break-after: auto;
    break-after: auto;
  }

  /* ===== Layout: header → 2-col body → footer ===== */
  .card-header {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: end;
    gap: 4mm;
    border-bottom: 1.5px solid var(--ink);
    padding-bottom: 2mm;
    margin-bottom: 4mm;
  }
  .card-header .title-block { min-width: 0; }
  .card-body {
    display: grid;
    grid-template-columns: minmax(0, 5fr) minmax(0, 6fr);
    gap: 7mm;
    flex: 1 1 auto;
    min-height: 0;
  }
  .card-body .col-identity {
    display: flex;
    flex-direction: column;
  }
  .card-body .col-tags {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  .card-corner {
    position: absolute;
    top: 0;
    right: 0;
    background: var(--rule);
    color: var(--paper);
    font-size: 8pt;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    padding: 2px 8px 3px;
    font-weight: bold;
  }
  .card-corner.mythos { background: #1d3a55; }
  .card-corner.logos  { background: #4a2622; }
  .card-corner.crew   { background: #355c3a; }
  .card-corner.extra  { background: #6a4f1d; }

  .card-character {
    font-size: 8.5pt;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.18em;
    margin-bottom: 1mm;
  }

  .card-title {
    font-size: 22pt;
    font-weight: bold;
    margin: 0;
    line-height: 1.05;
  }
  .card-themebook {
    font-size: 9pt;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.18em;
    margin: 1mm 0 0;
  }

  .card-mystery {
    background: var(--tag-bg);
    border-left: 4px solid var(--accent);
    padding: 4mm 5mm;
    margin: 0;
    font-style: italic;
    font-size: 13pt;
    line-height: 1.4;
    flex: 1 1 auto;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .card-mystery .kind {
    text-transform: uppercase;
    letter-spacing: 0.18em;
    font-size: 8pt;
    font-style: normal;
    color: var(--accent);
    font-weight: bold;
    display: block;
    margin-bottom: 2mm;
  }
  .card-mystery .quote {
    display: block;
  }

  .card-section-label {
    font-size: 8.5pt;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--accent);
    font-weight: bold;
    margin: 3mm 0 1.5mm 0;
    border-bottom: 1px dotted var(--muted);
    padding-bottom: 1mm;
  }

  .tag-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .tag-list li {
    display: grid;
    grid-template-columns: 18px 1fr auto;
    gap: 6px;
    align-items: baseline;
    padding: 1.5mm 0;
    font-size: 11pt;
    border-bottom: 1px dotted #ddd;
  }
  .tag-letter {
    font-weight: bold;
    color: var(--accent);
    font-size: 11pt;
  }
  .tag-text {
    font-family: "Helvetica Neue", Helvetica, "Inter", "Avenir Next", Arial, sans-serif;
  }
  .tag-flag {
    font-size: 8pt;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--muted);
    font-weight: bold;
  }
  .tag-flag.burnt { color: #8b1a1a; text-decoration: line-through; }

  .card-footer {
    margin-top: auto;
    padding-top: 4mm;
    border-top: 1px solid var(--rule);
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 9pt;
    color: var(--muted);
  }
  .track {
    display: flex;
    align-items: center;
    gap: 2mm;
  }
  .track .label {
    text-transform: uppercase;
    letter-spacing: 0.15em;
    font-size: 8pt;
    font-weight: bold;
    color: var(--accent);
  }
  .track .boxes { display: inline-flex; gap: 3px; }
  .track .box {
    width: 11px;
    height: 11px;
    border: 1.2px solid var(--ink);
    display: inline-block;
  }
  .track .box.filled { background: var(--ink); }
  .tracks { display: flex; gap: 8mm; }

  .improvements {
    font-size: 9pt;
    color: var(--muted);
    text-align: right;
  }
  .improvements .item {
    display: inline-block;
    background: var(--tag-bg);
    padding: 1px 6px;
    margin-left: 3px;
    border: 1px solid var(--muted);
  }

  @media screen {
    body {
      max-width: 240mm;
      margin: 0 auto;
      padding: 12mm 8mm;
    }
    .card {
      width: 210mm;
      height: auto;
      min-height: 148mm;
      margin: 0 auto 12mm auto;
      box-shadow: 0 0 16px rgba(0,0,0,0.15);
    }
  }
</style>
</head>
<body>

{% for theme in character.themes %}
<article class="card">
  <span class="card-corner {{ theme.type }}">{{ theme.type }}</span>

  <header class="card-header">
    <div class="title-block">
      <div class="card-character">{{ character.name }}</div>
      <h1 class="card-title">{{ theme.title }}</h1>
      <div class="card-themebook">{{ theme.themebook }}</div>
    </div>
  </header>

  <div class="card-body">
    <div class="col-identity">
      <div class="card-mystery">
        <span class="kind">{{ theme.mystery_or_identity.kind }}</span>
        <span class="quote">“{{ theme.mystery_or_identity.text }}”</span>
      </div>
    </div>

    <div class="col-tags">
      <div class="card-section-label">Power Tags</div>
      <ul class="tag-list">
        {% for t in theme.power_tags %}
        <li>
          <span class="tag-letter">{{ t.letter }}</span>
          <span class="tag-text">{{ t.tag }}</span>
          <span class="tag-flag">
            {%- if t.extra %}extra{% endif -%}
            {%- if t.burnt %}{% if t.extra %} · {% endif %}burnt{% endif -%}
          </span>
        </li>
        {% endfor %}
      </ul>

      <div class="card-section-label">Weakness Tags</div>
      <ul class="tag-list">
        {% for t in theme.weakness_tags %}
        <li>
          <span class="tag-letter">{{ t.letter }}</span>
          <span class="tag-text">{{ t.tag }}</span>
          <span class="tag-flag">{% if t.extra %}extra{% endif %}</span>
        </li>
        {% endfor %}
      </ul>
    </div>
  </div>

  <div class="card-footer">
    <div class="tracks">
      <div class="track">
        <span class="label">Att</span>
        <span class="boxes">
          {% for i in range(3) %}<span class="box {% if i < theme.attention|default(0) %}filled{% endif %}"></span>{% endfor %}
        </span>
      </div>
      <div class="track">
        <span class="label">{% if theme.type == 'mythos' %}Fade{% else %}Crack{% endif %}</span>
        <span class="boxes">
          {% for i in range(3) %}<span class="box {% if i < theme.fade_or_crack|default(0) %}filled{% endif %}"></span>{% endfor %}
        </span>
      </div>
    </div>
    {% if theme.improvements_taken %}
    <div class="improvements">
      <strong>Improvements:</strong>
      {% for imp in theme.improvements_taken %}<span class="item">{{ imp }}</span>{% endfor %}
    </div>
    {% endif %}
  </div>
</article>
{% endfor %}

</body>
</html>
